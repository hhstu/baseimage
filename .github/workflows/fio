name: fio

on:
  workflow_dispatch:
    inputs:
      tag:
        description: 'fio version, 如 3.41'

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      - name: Build the Docker image
        run: |
          FROM rockylinux/rockylinux:9 as  builder
          RUN yum makecache && yum  install git gcc g++ libaio libaio-devel  make -y && git clone https://github.com/axboe/fio.git && cd  fio && \
          git checkout fio-${{ github.event.inputs.tag }} && ./configure && make

          FROM rockylinux/rockylinux:9
          RUN yum makecache && yum  install libaio  libaio-devel  -y
          COPY --from=builder /fio/fio /usr/bin/fio
          CMD tail -f /dev/null
